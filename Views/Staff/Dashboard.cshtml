@model IEnumerable<SmartGrievancePortal.Models.Complaint>

@{
    ViewData["Title"] = "Staff Dashboard";
}

<div class="d-flex align-items-center mb-4 pb-2">
    <div class="rounded-circle bg-primary bg-opacity-10 p-3 me-3 text-primary d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
        <i class="fa-solid fa-gauge-high fs-4"></i>
    </div>
    <div>
        <h1 class="h3 mb-0 text-slate-800 fw-bold">Performance Overview</h1>
        <p class="text-muted small mb-0">Track and manage your assigned responsibilities.</p>
    </div>
</div>

<!-- Statistics Cards Row -->
<div class="row g-4 mb-5">
    <!-- Total Assignments Card -->
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100 rounded-4 overflow-hidden stat-card">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div class="bg-primary-soft p-3 rounded-circle text-primary">
                        <i class="fa-solid fa-inbox fs-5"></i>
                    </div>
                </div>
                <h3 class="fw-bold mb-1 text-slate-900">@ViewBag.TotalCount</h3>
                <p class="text-muted small mb-0 fw-medium">Total Number of Complaints</p>
            </div>
            <div class="progress" style="height: 4px;">
                <div class="progress-bar bg-primary" style="width: 100%"></div>
            </div>
        </div>
    </div>

    <!-- Pending/Action Card -->
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100 rounded-4 overflow-hidden stat-card">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div class="bg-warning-soft p-3 rounded-circle text-warning">
                        <i class="fa-solid fa-clock-rotate-left fs-5"></i>
                    </div>
                </div>
                <h3 class="fw-bold mb-1 text-slate-900">@ViewBag.PendingCount</h3>
                <p class="text-muted small mb-0 fw-medium">Needs Action</p>
            </div>
            <div class="progress" style="height: 4px;">
                <div class="progress-bar bg-warning" style="width: @(ViewBag.TotalCount > 0 ? (ViewBag.PendingCount * 100 / ViewBag.TotalCount) : 0)%"></div>
            </div>
        </div>
    </div>

    <!-- Resolved Card -->
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100 rounded-4 overflow-hidden stat-card">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div class="bg-success-soft p-3 rounded-circle text-success">
                        <i class="fa-solid fa-check-double fs-5"></i>
                    </div>
                </div>
                <h3 class="fw-bold mb-1 text-slate-900">@ViewBag.ResolvedCount</h3>
                <p class="text-muted small mb-0 fw-medium">Successfully Resolved</p>
            </div>
            <div class="progress" style="height: 4px;">
                <div class="progress-bar bg-success" style="width: @(ViewBag.TotalCount > 0 ? (ViewBag.ResolvedCount * 100 / ViewBag.TotalCount) : 0)%"></div>
            </div>
        </div>
    </div>
</div>

<div class="d-flex align-items-center mb-4 pb-2">
    <div class="rounded-circle bg-primary bg-opacity-10 p-3 me-3 text-primary d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
        <i class="fa-solid fa-list-check fs-4"></i>
    </div>
    <div>
        <h1 class="h3 mb-0 text-slate-800 fw-bold">Detailed Task List</h1>
        <p class="text-muted small mb-0">View more details or update status for each complaint.</p>
    </div>
</div>

<div class="card shadow-sm border-0 overflow-hidden">
    <div class="card-header bg-white py-3 border-bottom-0">
        <h5 class="mb-0 fw-bold text-slate-700">Active Grievances</h5>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-slate-600">
                    <tr>
                        <th class="ps-4 py-3 text-uppercase small fw-bold">Complaint Title</th>
                        <th class="py-3 text-uppercase small fw-bold">Student</th>
                        <th class="py-3 text-uppercase small fw-bold">Category</th>
                        <th class="py-3 text-uppercase small fw-bold">Status</th>
                        <th class="pe-4 py-3 text-uppercase small fw-bold text-end">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="py-5 text-center text-muted">
                                <i class="fa-solid fa-inbox d-block fs-1 mb-3 opacity-25"></i>
                                No tasks assigned to you at the moment.
                            </td>
                        </tr>
                    }
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="fw-bold text-slate-800">@item.Title</div>
                                <div class="text-muted small text-truncate" style="max-width: 300px;">@item.Description</div>
                            </td>
                            <td>
                                <div class="fw-medium">@item.Student?.FullName</div>
                                <div class="text-muted smallest text-uppercase">@item.StudentRollNumber</div>
                            </td>
                            <td>
                                <span class="badge bg-soft-blue text-primary px-3 py-2 rounded-pill border-0">
                                    @item.Category?.Name
                                </span>
                            </td>
                            <td>
                                @{
                                    var badgeClass = item.Status switch
                                    {
                                        SmartGrievancePortal.Models.ComplaintStatus.Pending => "bg-warning-soft text-warning",
                                        SmartGrievancePortal.Models.ComplaintStatus.InProgress => "bg-info-soft text-info",
                                        SmartGrievancePortal.Models.ComplaintStatus.Resolved => "bg-success-soft text-success",
                                        _ => "bg-secondary-soft text-secondary"
                                    };
                                }
                                <span class="badge @badgeClass px-3 py-2 rounded-pill border-0 fw-bold" style="font-size: 0.75rem;">
                                    <i class="fa-solid fa-circle me-1 small"></i> @item.Status
                                </span>
                            </td>
                            <td class="pe-4 text-end">
                                <a asp-action="Update" asp-route-id="@item.Id" class="btn btn-sm btn-action rounded-pill px-4 shadow-sm">
                                    Update Status
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .text-slate-800 { color: #1e293b; }
    .text-slate-700 { color: #334155; }
    .text-slate-600 { color: #475569; }
    .smallest { font-size: 0.7rem; }
    
    .bg-soft-blue, .bg-primary-soft { background-color: #eff6ff; }
    .bg-warning-soft { background-color: #fffbeb; }
    .bg-info-soft { background-color: #f0f9ff; }
    .bg-success-soft { background-color: #f0fdf4; }
    .bg-secondary-soft { background-color: #f8fafc; }
    
    .stat-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .stat-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05) !important;
    }
    
    .btn-action {
        background-color: white;
        color: #2563eb;
        border: 1px solid #e2e8f0;
        font-weight: 600;
        transition: all 0.2s;
    }
    .btn-action:hover {
        background-color: #2563eb;
        color: white;
        border-color: #2563eb;
        transform: translateY(-1px);
    }
</style>

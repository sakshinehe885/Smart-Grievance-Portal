@model SmartGrievancePortal.Models.ApplicationUser

@{
    ViewData["Title"] = "My Profile";
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
                <!-- Header / Banner -->
                <div class="bg-primary pt-4 pb-4 px-4 position-relative" style="background: linear-gradient(135deg, #1e3a8a 0%, #3b82f6 100%);">
                    <div class="d-flex align-items-center flex-wrap">
                        <div class="bg-white p-1 rounded-circle shadow-sm" style="z-index: 2;">
                            <img src="https://ui-avatars.com/api/?name=@(System.Net.WebUtility.UrlEncode(Model.FullName))&background=random&color=fff&size=128" class="rounded-circle" style="width: 120px; height: 120px; object-fit: cover; border: 4px solid white;" alt="Profile Photo">
                        </div>
                        <div class="ms-sm-4 mt-4 mt-sm-0 text-white">
                            <h2 class="fw-bold mb-1">@Model.FullName</h2>
                            <p class="mb-0 opacity-75 fs-5">Official Staff Account - @Model.Department</p>
                        </div>
                    </div>
                </div>

                <div class="card-body pt-4 px-4 pb-4 bg-light">
                    <div class="row">
                        <!-- Personal Info -->
                        <div class="col-md-6 mb-4">
                            <div class="card h-100 border-0 shadow-sm rounded-3">
                                <div class="card-body p-4">
                                    <h5 class="fw-bold text-primary border-bottom pb-2 mb-4">
                                        <i class="fa-solid fa-address-card me-2"></i>Personal Details
                                    </h5>
                                    
                                    <div class="mb-3">
                                        <small class="text-muted d-block fw-bold text-uppercase" style="font-size: 0.75rem;">Email Address</small>
                                        <span class="fs-6 text-dark fw-medium">@Model.Email</span>
                                    </div>
                                    <div class="mb-3">
                                        <small class="text-muted d-block fw-bold text-uppercase" style="font-size: 0.75rem;">Gender</small>
                                        <span class="fs-6 text-dark fw-medium">@Model.Gender</span>
                                    </div>
                                    <div class="mb-3">
                                        <small class="text-muted d-block fw-bold text-uppercase" style="font-size: 0.75rem;">Contact Number</small>
                                        <span class="fs-6 text-dark fw-medium">@Model.PhoneNumber</span>
                                    </div>
                                    <div class="mb-0">
                                        <small class="text-muted d-block fw-bold text-uppercase" style="font-size: 0.75rem;">Permanent Address</small>
                                        <span class="fs-6 text-dark fw-medium">@Model.Address</span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Professional Info -->
                        <div class="col-md-6 mb-4">
                            <div class="card h-100 border-0 shadow-sm rounded-3">
                                <div class="card-body p-4">
                                    <h5 class="fw-bold text-primary border-bottom pb-2 mb-4">
                                        <i class="fa-solid fa-briefcase me-2"></i>Professional Details
                                    </h5>
                                    
                                    <div class="mb-3">
                                        <small class="text-muted d-block fw-bold text-uppercase" style="font-size: 0.75rem;">Department</small>
                                        <div class="mt-1">
                                            <span class="badge bg-soft-blue text-primary px-3 py-2 rounded-pill border-0">
                                                @Model.Department
                                            </span>
                                        </div>
                                    </div>
                                    <div class="mb-3">
                                        <small class="text-muted d-block fw-bold text-uppercase" style="font-size: 0.75rem;">Staff Category</small>
                                        <span class="fs-6 text-dark fw-medium">Administrative Specialist</span>
                                    </div>
                                    <div class="mb-0">
                                        <small class="text-muted d-block fw-bold text-uppercase" style="font-size: 0.75rem;">Employee Status</small>
                                        <div class="mt-1">
                                            <span class="badge bg-success rounded-pill px-3 py-2 text-white">
                                                <i class="fa-solid fa-circle-check me-1"></i>
                                                Active Employee
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-soft-blue { background-color: #eff6ff; }
</style>

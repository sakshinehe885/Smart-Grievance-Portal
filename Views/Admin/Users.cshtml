@model IEnumerable<SmartGrievancePortal.Models.ApplicationUser>
@{
    ViewData["Title"] = "Manage Users";
}

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4 mt-2">
    <div>
        <h1 class="h3 mb-0 text-slate-800 fw-bold">Manage Users</h1>
        <p class="text-muted small mb-0">View and manage all registered accounts on the portal.</p>
    </div>
    <div class="filter-pills d-flex align-items-center bg-white p-1 rounded-pill shadow-sm border">
        <a asp-action="Users" asp-route-role="" 
           class="btn @(ViewBag.SelectedRole == "All" ? "btn-active shadow-sm" : "btn-inactive")">
            All Users
        </a>
        <a asp-action="Users" asp-route-role="Student" 
           class="btn @(ViewBag.SelectedRole == "Student" ? "btn-active shadow-sm" : "btn-inactive")">
            Students
        </a>
        <a asp-action="Users" asp-route-role="Staff" 
           class="btn @(ViewBag.SelectedRole == "Staff" ? "btn-active shadow-sm" : "btn-inactive")">
            Staff Members
        </a>
    </div>
</div>

<style>
    .text-slate-800 { color: #1e293b; }
    
    .filter-pills .btn {
        border-radius: 50px;
        padding: 0.5rem 1.25rem;
        font-weight: 600;
        font-size: 0.85rem;
        border: none;
        transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
        white-space: nowrap;
    }
    
    .filter-pills .btn-inactive {
        background-color: transparent;
        color: #64748b;
    }
    
    .filter-pills .btn-inactive:hover {
        background-color: #f8fafc;
        color: #2563eb;
    }
    
    .filter-pills .btn-active {
        background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
        color: white !important;
    }
</style>

<div class="card shadow-sm border-0">
    <div class="card-header bg-white py-3">
        <h5 class="mb-0 fw-bold text-slate-700">
            @if (ViewBag.SelectedRole == "All") { <span>All Registered Users</span> }
            else if (ViewBag.SelectedRole == "Student") { <span>Registered Students</span> }
            else { <span>Staff Members</span> }
        </h5>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Full Name</th>
                        <th>Email</th>
                        <th>Department</th>
                        <th class="pe-4 text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-medium">@user.FullName</td>
                            <td>@user.Email</td>
                            <td>
                                @if (!string.IsNullOrEmpty(user.Department))
                                {
                                    <span class="badge bg-light text-dark border">@user.Department</span>
                                }
                                else
                                {
                                    <span class="text-muted small">N/A</span>
                                }
                            </td>
                            <td class="pe-4 text-end">
                                <form asp-action="DeleteStaff" asp-route-id="@user.Id" method="post" onsubmit="return confirm('Are you sure you want to delete this user?');" style="display:inline;">
                                    <button type="submit" class="btn btn-sm btn-outline-danger border-0" title="Delete User">
                                        <i class="fa-solid fa-trash-can"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

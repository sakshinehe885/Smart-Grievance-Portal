@model IEnumerable<SmartGrievancePortal.Models.Complaint>

@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="mt-4 mb-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="h4 mb-0 text-slate-800 fw-bold">Overview</h2>
        <div>
            <a asp-action="CreateStaff" class="btn btn-sm btn-outline-primary shadow-sm me-2"><i class="fa-solid fa-user-plus me-2"></i>New Staff</a>
            <a asp-action="Users" class="btn btn-sm btn-outline-secondary shadow-sm"><i class="fa-solid fa-users me-2"></i>Manage Users</a>
        </div>
    </div>

    <!-- Statistics Rows -->
    <div class="row mb-2">
        <!-- Row 1: Complaint Stats -->
        <div class="col-md-4 mb-3">
            <div class="card shadow-sm border-0 h-100 py-3 border-start border-4 border-primary">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col me-2">
                            <div class="text-xs fw-bold text-primary text-uppercase mb-1" style="font-size: 0.8rem;">Total Complaints</div>
                            <div class="h4 mb-0 fw-bold text-gray-800">@ViewBag.TotalComplaints</div>
                        </div>
                        <div class="col-auto">
                            <i class="fa-solid fa-clipboard-list fa-2x text-body-tertiary opacity-50"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card shadow-sm border-0 h-100 py-3 border-start border-4 border-success">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col me-2">
                            <div class="text-xs fw-bold text-success text-uppercase mb-1" style="font-size: 0.8rem;">Resolved Complaints</div>
                            <div class="h4 mb-0 fw-bold text-gray-800">@ViewBag.ResolvedComplaints</div>
                        </div>
                        <div class="col-auto">
                            <i class="fa-solid fa-check-double fa-2x text-body-tertiary opacity-50"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card shadow-sm border-0 h-100 py-3 border-start border-4 border-warning">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col me-2">
                            <div class="text-xs fw-bold text-warning text-uppercase mb-1" style="font-size: 0.8rem;">Pending Complaints</div>
                            <div class="h4 mb-0 fw-bold text-gray-800">@ViewBag.PendingComplaints</div>
                        </div>
                        <div class="col-auto">
                            <i class="fa-solid fa-hourglass-half fa-2x text-body-tertiary opacity-50"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="row mb-4">
        <!-- Row 2: User Stats -->
        <div class="col-md-6 mb-3">
            <div class="card shadow-sm border-0 h-100 py-3 border-start border-4 border-info">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col me-2">
                            <div class="text-xs fw-bold text-info text-uppercase mb-1" style="font-size: 0.8rem;">Total Number of Students</div>
                            <div class="h4 mb-0 fw-bold text-gray-800">@ViewBag.TotalStudents</div>
                        </div>
                        <div class="col-auto">
                            <i class="fa-solid fa-user-graduate fa-2x text-body-tertiary opacity-50"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-6 mb-3">
            <div class="card shadow-sm border-0 h-100 py-3 border-start border-4 border-secondary">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col me-2">
                            <div class="text-xs fw-bold text-secondary text-uppercase mb-1" style="font-size: 0.8rem;">Total Number of Staff Members</div>
                            <div class="h4 mb-0 fw-bold text-gray-800">@ViewBag.TotalStaff</div>
                        </div>
                        <div class="col-auto">
                            <i class="fa-solid fa-user-tie fa-2x text-body-tertiary opacity-50"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
        <div class="card-body py-3 px-4">
            <form asp-action="Dashboard" method="get" class="d-flex gap-3 align-items-center">
                <i class="fa-solid fa-filter text-muted"></i>
                <label for="categoryId" class="form-label mb-0 fw-semibold text-secondary">Filter By Category:</label>
                <select name="categoryId" id="categoryId" class="form-select w-auto shadow-sm border-0" asp-items="ViewBag.Categories" onchange="this.form.submit()">
                    <option value="">All Categories</option>
                </select>
            </form>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Title</th>
                            <th>Student</th>
                            <th>Category</th>
                            <th>Details</th>
                            <th>Date</th>
                            <th>Status</th>
                            <th>Assigned Staff</th>
                            <th class="pe-4 text-end">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                @foreach (var item in Model) {
                        <tr>
                            <td class="ps-4 fw-medium text-dark flex-wrap" style="max-width: 200px;">@item.Title</td>
                            <td>
                                <div class="d-flex flex-column">
                                    <span class="fw-semibold">@item.Student?.FullName</span>
                                    <span class="small text-muted">@item.Student?.Email</span>
                                </div>
                            </td>
                            <td><span class="badge bg-light text-secondary border">@item.Category?.Name</span></td>
                            <td class="text-truncate" style="max-width: 200px;" title="@item.Description">@item.Description</td>
                            <td class="text-muted small">@item.DateCreated.ToString("g")</td>
                            <td>
                                @{
                                    var badgeClass = item.Status switch
                                    {
                                        SmartGrievancePortal.Models.ComplaintStatus.Pending => "bg-warning text-dark",
                                        SmartGrievancePortal.Models.ComplaintStatus.InProgress => "bg-info text-dark",
                                        SmartGrievancePortal.Models.ComplaintStatus.Resolved => "bg-success",
                                        _ => "bg-secondary"
                                    };
                                }
                                <span class="badge @badgeClass rounded-pill">@item.Status</span>
                            </td>
                            <td>
                                <span class="badge @(item.AssignedStaff == null ? "bg-light text-danger border" : "bg-light text-primary border")">
                                    <i class="fa-solid fa-user me-1"></i> @(item.AssignedStaff?.FullName ?? "Unassigned")
                                </span>
                            </td>
                            <td class="pe-4 text-end">
                                <div class="btn-group shadow-sm" role="group">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-light text-primary border" title="Details/Respond"><i class="fa-solid fa-eye"></i></a>
                                    <a asp-action="AssignStaff" asp-route-id="@item.Id" class="btn btn-sm btn-light text-info border" title="Assign Staff"><i class="fa-solid fa-user-tag"></i></a>
                                </div>
                            </td>
                        </tr>
                }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

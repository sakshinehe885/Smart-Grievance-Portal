@model SmartGrievancePortal.Models.Complaint

@{
    ViewData["Title"] = "Complaint Details";
}

<div class="row mt-4">
    <div class="col-md-8">
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                <h5 class="mb-0 fw-bold text-slate-700">Complaint Information</h5>
                <span class="badge bg-light text-primary border">ID: #@Model.Id</span>
            </div>
            <div class="card-body p-4">
                <div class="row mb-4">
                    <div class="col-12">
                        <h4 class="fw-bold mb-3">@Model.Title</h4>
                        <p class="text-muted border-start ps-3 py-1">@Model.Description</p>
                    </div>
                </div>

                <div class="row g-4">
                    <div class="col-md-6">
                        <h6 class="text-uppercase small fw-bold text-muted mb-3 border-bottom pb-2">Student Details</h6>
                        <div class="d-flex align-items-center gap-3">
                            <div class="flex-shrink-0">
                                <img src="@(string.IsNullOrEmpty(Model.Student?.PassportPhotoPath) ? "/img/default-avatar.png" : Model.Student.PassportPhotoPath)" 
                                     class="rounded-circle border shadow-sm" 
                                     style="width: 60px; height: 60px; object-fit: cover;" 
                                     alt="Student Photo" 
                                     onerror="this.onerror=null; this.src='https://ui-avatars.com/api/?name=' + encodeURIComponent('@(Model.Student?.FullName ?? "User")') + '&background=random&color=fff';" />
                            </div>
                            <div class="d-flex flex-column gap-1">
                                <div><span class="text-muted small">Name:</span> <span class="fw-bold">@Model.Student?.FullName</span></div>
                                <div><span class="text-muted small">Email:</span> <span class="fw-medium small">@Model.Student?.Email</span></div>
                                <div><span class="text-muted small">ID:</span> <span class="fw-medium small">@(Model.StudentRollNumber ?? "N/A")</span></div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <h6 class="text-uppercase small fw-bold text-muted mb-3 border-bottom pb-2">Academic Info</h6>
                        <div class="d-flex flex-column gap-2">
                            <div><span class="text-muted small">Category:</span> <span class="badge bg-light text-dark border">@(Model.Category?.Name ?? "N/A")</span></div>
                            <div><span class="text-muted small">Course:</span> <span class="fw-medium">@(Model.StudentCourse ?? "N/A")</span></div>
                            <div><span class="text-muted small">Year:</span> <span class="fw-medium">@(Model.StudentYear ?? "N/A")</span></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.PhotoPath))
        {
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0 fw-bold text-slate-700">Attached Evidence</h5>
                </div>
                <div class="card-body text-center p-3">
                    <img src="@Model.PhotoPath" alt="Evidence" class="img-fluid rounded shadow-sm" style="max-height: 500px;" />
                </div>
            </div>
        }

        <div class="card shadow-sm border-0 mb-4 border-start border-primary border-4">
            <div class="card-header bg-white py-3">
                <h5 class="mb-0 fw-bold text-primary">Update Status</h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="AddResponse" method="post" class="row align-items-end gx-3">
                    <input type="hidden" name="id" value="@Model.Id" />
                    <div class="col-md-8">
                        <label class="form-label fw-bold small text-muted text-uppercase">New Status</label>
                        <select name="status" class="form-select bg-light border-0 shadow-sm" asp-items="Html.GetEnumSelectList<SmartGrievancePortal.Models.ComplaintStatus>()" required>
                        </select>
                    </div>
                    <div class="col-md-4 mt-3 mt-md-0">
                        <button type="submit" class="btn btn-primary w-100 shadow-sm py-2">Update Ticket</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm border-0 mb-4 overflow-hidden">
            <div class="card-header bg-slate-800 text-white py-3">
                <h5 class="mb-0 fw-bold"><i class="fa-solid fa-clock-rotate-left me-2"></i>Status & Timeline</h5>
            </div>
            <div class="card-body p-4">
                <div class="mb-4 text-center">
                    @{
                        var badgeClass = Model.Status switch
                        {
                            SmartGrievancePortal.Models.ComplaintStatus.Pending => "bg-warning text-dark",
                            SmartGrievancePortal.Models.ComplaintStatus.InProgress => "bg-info text-dark",
                            SmartGrievancePortal.Models.ComplaintStatus.Resolved => "bg-success",
                            _ => "bg-secondary"
                        };
                    }
                    <h3 class="mb-1"><span class="badge @badgeClass rounded-pill px-4">@Model.Status</span></h3>
                    <p class="text-muted small mb-0">Updated on @DateTime.Now.ToString("g")</p>
                </div>

                <div class="d-flex flex-column gap-3 border-top pt-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="text-muted small">Registered:</span>
                        <span class="fw-medium small">@Model.DateCreated.ToString("g")</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="text-muted small">Assigned To:</span>
                        <span class="fw-bold small text-primary">@(Model.AssignedStaff?.FullName ?? "PENDING ASSIGNMENT")</span>
                    </div>
                    @if (Model.DateResolved.HasValue)
                    {
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="text-muted small">Resolved:</span>
                            <span class="fw-medium small">@Model.DateResolved.Value.ToString("g")</span>
                        </div>
                    }
                </div>

                <div class="mt-4 d-grid gap-2">
                    <a asp-action="AssignStaff" asp-route-id="@Model.Id" class="btn btn-outline-info shadow-sm">
                        <i class="fa-solid fa-user-tag me-2"></i> @(string.IsNullOrEmpty(Model.AssignedStaffId) ? "Assign Staff" : "Re-assign Staff")
                    </a>
                    <a asp-action="Dashboard" class="btn btn-link text-muted text-decoration-none small text-center">
                        <i class="fa-solid fa-arrow-left me-1"></i> Back to Dashboard
                    </a>
                </div>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.StaffRemarks))
        {
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-light py-2">
                    <h6 class="mb-0 fw-bold small text-uppercase">Staff Remarks</h6>
                </div>
                <div class="card-body p-3">
                    <p class="mb-0 small fst-italic text-secondary">"@Model.StaffRemarks"</p>
                </div>
            </div>
        }
    </div>
</div>

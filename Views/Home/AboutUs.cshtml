@{
    ViewData["Title"] = "About Us";
}

<div class="light-blue-container py-5">
    <div class="container">
        <!-- Hero Section -->
        <div class="text-center mb-5 animate-fadeIn">
            <h1 class="display-4 fw-bold text-dark mb-3">Our Mission is to<br><span style="color: #0ea5e9;">Fix Your Perspective</span></h1>
            <p class="lead text-muted mx-auto" style="max-width: 700px;">
                FixMyIssue is a state-of-the-art grievance redressal platform designed to bridge the gap between students, staff, and administration.
            </p>
        </div>

        <div class="row g-4 mt-4">
            <!-- Mission Card -->
            <div class="col-lg-6">
                <div class="details-group-box h-100 shadow-sm border-0 bg-white p-5 text-center" style="border-radius: 30px;">
                    <div class="login-header-icon mx-auto mb-4" style="background-color: #f0fdf4; color: #16a34a;">
                        <i class="fa-solid fa-bullseye"></i>
                    </div>
                    <h3 class="fw-bold mb-3">Our Mission</h3>
                    <p class="text-muted mb-0">
                        To provide a seamless, transparent, and efficient platform for reporting and resolving concerns, ensuring that every voice is heard and every issue is addressed with accountability.
                    </p>
                </div>
            </div>

            <!-- Vision Card -->
            <div class="col-lg-6">
                <div class="details-group-box h-100 shadow-sm border-0 bg-white p-5 text-center" style="border-radius: 30px;">
                    <div class="login-header-icon mx-auto mb-4" style="background-color: #f0f9ff; color: #0369a1;">
                        <i class="fa-solid fa-eye"></i>
                    </div>
                    <h3 class="fw-bold mb-3">Our Vision</h3>
                    <p class="text-muted mb-0">
                        To become the gold standard for institutional communication, where technology and empathy work together to create a problem-free environment for all stakeholders.
                    </p>
                </div>
            </div>
        </div>

        <!-- Core Values Section -->
        <div class="mt-5 pt-5">
            <h2 class="text-center fw-bold mb-5">Our Core Values</h2>
            <div class="row g-4 text-center">
                <div class="col-md-4">
                    <div class="p-4">
                        <div class="mb-3 text-primary fs-1"><i class="fa-solid fa-shield-halved"></i></div>
                        <h5 class="fw-bold">Transparency</h5>
                        <p class="small text-muted">Real-time tracking of every complaint ensures total visibility for users.</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="p-4">
                        <div class="mb-3 text-success fs-1"><i class="fa-solid fa-bolt-lightning"></i></div>
                        <h5 class="fw-bold">Efficiency</h5>
                        <p class="small text-muted">Direct routing to the relevant staff members minimizes resolution time.</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="p-4">
                        <div class="mb-3 text-warning fs-1"><i class="fa-solid fa-handshake"></i></div>
                        <h5 class="fw-bold">Accountability</h5>
                        <h5 class="fw-bold">Accountability</h5>
                        <p class="small text-muted">A structured hierarchy ensures every issue reaches a final resolution.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .animate-fadeIn {
        animation: fadeInUp 1s ease-out;
    }
</style>

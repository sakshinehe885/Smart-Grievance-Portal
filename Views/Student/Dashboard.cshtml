@model IEnumerable<SmartGrievancePortal.Models.Complaint>

@{
    ViewData["Title"] = "Student Dashboard";
}

<div class="container-fluid py-2">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0 text-gray-800 fw-bold">My Complaints</h1>
        <a asp-action="Create" class="btn btn-primary-custom"><i class="fa-solid fa-plus me-2"></i>Submit New Complaint</a>
    </div>

    <!-- Statistics Row -->
    <div class="row mb-4">
        <div class="col-xl-3 col-sm-6 mb-3 mb-xl-0">
            <div class="card shadow-sm border-0 h-100 py-2 border-start border-4 border-primary">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col me-2">
                            <div class="text-xs fw-bold text-primary text-uppercase mb-1" style="font-size: 0.8rem;">Total Complaints</div>
                            <div class="h5 mb-0 fw-bold text-gray-800">@ViewBag.TotalComplaints</div>
                        </div>
                        <div class="col-auto">
                            <i class="fa-solid fa-clipboard-list fa-2x text-body-tertiary opacity-50"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-sm-6 mb-3 mb-xl-0">
            <div class="card shadow-sm border-0 h-100 py-2 border-start border-4 border-warning">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col me-2">
                            <div class="text-xs fw-bold text-warning text-uppercase mb-1" style="font-size: 0.8rem;">Pending</div>
                            <div class="h5 mb-0 fw-bold text-gray-800">@ViewBag.PendingComplaints</div>
                        </div>
                        <div class="col-auto">
                            <i class="fa-solid fa-clock fa-2x text-body-tertiary opacity-50"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-sm-6 mb-3 mb-sm-0">
            <div class="card shadow-sm border-0 h-100 py-2 border-start border-4 border-success">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col me-2">
                            <div class="text-xs fw-bold text-success text-uppercase mb-1" style="font-size: 0.8rem;">Resolved</div>
                            <div class="h5 mb-0 fw-bold text-gray-800">@ViewBag.ResolvedComplaints</div>
                        </div>
                        <div class="col-auto">
                            <i class="fa-solid fa-check-circle fa-2x text-body-tertiary opacity-50"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-sm-6">
            <div class="card shadow-sm border-0 h-100 py-2 border-start border-4 border-danger">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col me-2">
                            <div class="text-xs fw-bold text-danger text-uppercase mb-1" style="font-size: 0.8rem;">Rejected</div>
                            <div class="h5 mb-0 fw-bold text-gray-800">@ViewBag.RejectedComplaints</div>
                        </div>
                        <div class="col-auto">
                            <i class="fa-solid fa-circle-xmark fa-2x text-body-tertiary opacity-50"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4 py-3">@Html.DisplayNameFor(model => model.Title)</th>
                            <th class="py-3">@Html.DisplayNameFor(model => model.Category)</th>
                            <th class="py-3">@Html.DisplayNameFor(model => model.DateCreated)</th>
                            <th class="py-3">@Html.DisplayNameFor(model => model.Status)</th>
                            <th class="pe-4 py-3 text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                @foreach (var item in Model) {
                        <tr>
                            <td class="ps-4 fw-medium text-dark">@Html.DisplayFor(modelItem => item.Title)</td>
                            <td><span class="badge bg-light text-secondary border">@Html.DisplayFor(modelItem => item.Category!.Name)</span></td>
                            <td><span class="text-muted">@item.DateCreated.ToShortDateString()</span></td>
                            <td>
                                @{
                                    var badgeClass = item.Status switch
                                    {
                                        SmartGrievancePortal.Models.ComplaintStatus.Pending => "bg-warning text-dark",
                                        SmartGrievancePortal.Models.ComplaintStatus.InProgress => "bg-info text-dark",
                                        SmartGrievancePortal.Models.ComplaintStatus.Resolved => "bg-success",
                                        _ => "bg-secondary"
                                    };
                                }
                                <span class="badge @badgeClass rounded-pill px-3 py-2">
                                    @Html.DisplayFor(modelItem => item.Status)
                                </span>
                            </td>
                            <td class="pe-4 text-end">
                                <a asp-action="Track" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary rounded-pill px-3"><i class="fa-solid fa-location-crosshairs me-1"></i>Track</a>
                            </td>
                        </tr>
                }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

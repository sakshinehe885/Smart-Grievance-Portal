<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FixMyIssue</title>
    <!-- Use FontAwesome for the icons in How It Works -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css?v=2.0" asp-append-version="true" />
    <link rel="stylesheet" href="~/SmartGrievancePortal.styles.css" asp-append-version="true" />
</head>
<body class="d-flex flex-column min-vh-100">
    <header class="bg-white">
        <nav class="navbar navbar-expand-lg navbar-light container pt-3 pb-3">
            <a class="navbar-brand text-decoration-none" asp-area="" asp-controller="Home" asp-action="Index">
                <!-- Custom SVG Logo Matching FixMyIssue -->
                <div class="d-flex align-items-center">
                    <svg width="45" height="45" viewBox="0 0 120 120" xmlns="http://www.w3.org/2000/svg">
                        <circle cx="60" cy="60" r="50" fill="#e0f2fe" />
                        <path d="M60 10 A50 50 0 0 1 110 60" fill="none" stroke="#2563eb" stroke-width="8" stroke-linecap="round"/>
                        <path d="M60 110 A50 50 0 0 1 10 60" fill="none" stroke="#16a34a" stroke-width="8" stroke-linecap="round"/>
                        <!-- The exclamation mark combined from ! and check -->
                        <text x="35" y="75" font-family="Arial" font-size="50" font-weight="900" fill="#eab308">!</text>
                        <path d="M65 60 L75 70 L100 45" fill="none" stroke="#16a34a" stroke-width="10" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    <div class="ms-2">
                        <div style="font-size: 1.6rem; font-weight: 800; line-height: 1;">
                            <span style="color: #034898;">Fix</span><span style="color: #0ea5e9;">My</span><span style="color: #16a34a;">Issue</span>
                        </div>
                        <div style="font-size: 0.65rem; color: #64748b; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; margin-top: 2px;">Report. Track. Resolve.</div>
                    </div>
                </div>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent"
                    aria-controls="navbarContent" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarContent">
                <ul class="navbar-nav ms-auto mb-2 mb-lg-0 align-items-center">
                    <li class="nav-item">
                        <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="AboutUs">About Us</a>
                    </li>
                    @if (!User.IsInRole("Admin"))
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Support">Support</a>
                        </li>
                    }
                </ul>
                <div class="d-flex align-items-center">
                    <partial name="_LoginPartial" />
                    @if (User.Identity!.IsAuthenticated && User.IsInRole("Admin"))
                    {
                        <a class="btn btn-primary-custom ms-3 shadow-sm" asp-controller="Admin" asp-action="Dashboard">Admin Dashboard</a>
                    }
                    else if (User.Identity!.IsAuthenticated && User.IsInRole("Staff"))
                    {
                        <a class="btn btn-primary-custom ms-3 shadow-sm" asp-controller="Staff" asp-action="Dashboard">Staff Dashboard</a>
                    }
                    else if (User.Identity!.IsAuthenticated && User.IsInRole("Student"))
                    {
                        <a class="btn btn-primary-custom ms-3 shadow-sm" asp-controller="Student" asp-action="Dashboard">Student Dashboard</a>
                    }
                </div>
            </div>
        </nav>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <footer class="border-top text-muted bg-white py-4 mt-auto">
        <div class="container text-center">
            &copy; 2026 - FixMyIssue - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
